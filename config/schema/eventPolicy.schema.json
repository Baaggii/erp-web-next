{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event Policy",
  "type": "object",
  "required": [
    "policy_key",
    "policy_name",
    "event_type",
    "condition_json",
    "action_json"
  ],
  "properties": {
    "policy_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "policy_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "event_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "module_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": 0
    },
    "is_active": {
      "type": "boolean"
    },
    "stop_on_match": {
      "type": "boolean"
    },
    "condition_json": {
      "$ref": "#/definitions/conditionGroup"
    },
    "action_json": {
      "type": "object",
      "required": [
        "actions"
      ],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "create_transaction",
                  "update_transaction",
                  "create_notification",
                  "notify",
                  "update_twin",
                  "call_procedure",
                  "enqueue_ai_review",
                  "reserve_budget",
                  "reserve_resource",
                  "block_operation",
                  "write_audit_note"
                ]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "ai_policy_json": {
      "type": [
        "object",
        "null"
      ]
    },
    "source_table": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "source_transaction_type": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 120
    },
    "source_transaction_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "is_sample": {
      "type": "boolean"
    }
  },
  "definitions": {
    "conditionRule": {
      "type": "object",
      "required": [
        "field",
        "operator"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "enum": [
            "=",
            "!=",
            ">",
            ">=",
            "<",
            "<=",
            "in",
            "not_in",
            "contains",
            "exists",
            "not_exists",
            "starts_with",
            "ends_with"
          ]
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "conditionGroup": {
      "type": "object",
      "required": [
        "logic",
        "rules"
      ],
      "properties": {
        "logic": {
          "type": "string",
          "enum": [
            "and",
            "or"
          ]
        },
        "rules": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/definitions/conditionRule"
              },
              {
                "$ref": "#/definitions/conditionGroup"
              }
            ]
          }
        }
      },
      "additionalProperties": false
    }
  }
}
