[
  {
    "policy_key": "inventory_shortage_investigation",
    "policy_name": "Inventory shortage triggers investigation + risk",
    "event_type": "inventory.shortage.detected",
    "module_key": "inventory",
    "priority": 10,
    "is_active": true,
    "stop_on_match": false,
    "condition_json": {
      "logic": "and",
      "rules": [
        { "field": "payload.shortageQty", "operator": ">", "value": 10 },
        { "field": "payload.severity", "operator": "in", "value": ["high", "critical"] }
      ]
    },
    "action_json": {
      "actions": [
        {
          "type": "create_transaction",
          "transactionType": "plan_investigation",
          "tableName": "transactions_plan_investigation",
          "mapping": {
            "annot": "Auto-created from shortage event",
            "linked_record_id": "source.recordId",
            "priority": "payload.severity"
          }
        },
        {
          "type": "notify",
          "target": { "mode": "roles", "values": ["SENIOR_INVENTORY", "AUDITOR"] },
          "message": "Inventory shortage detected"
        },
        {
          "type": "update_twin",
          "twin": "risk_state",
          "mapping": {
            "risk_key": "inventory_shortage",
            "entity_type": "inventory_item",
            "entity_ref_id": "payload.itemId",
            "severity": "payload.severity",
            "status_code": "open"
          }
        }
      ]
    }
  }
]
